# Copy to .env for local (non-Docker) runs. docker-compose sets these directly.
DEBUG=True
SECRET_KEY=dev-insecure-secret-key-change-me
ALLOWED_HOSTS=*

DATABASE_URL=postgres://blog:blog@localhost:5432/blog
REDIS_URL=redis://localhost:6379/0

# Set True to run Celery tasks synchronously (no worker needed).
CELERY_TASK_ALWAYS_EAGER=False

# JWT lifetimes
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Cache TTLs (seconds)
CACHE_TTL_POST_LIST=60
CACHE_TTL_POST_DETAIL=120

# Where the SPA is reachable (used to build password-reset links).
FRONTEND_URL=http://localhost:5173

# Email: leave EMAIL_HOST blank to print mail to the console (dev). Set these
# to deliver real password-reset emails via SMTP. Example for Gmail:
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_USE_TLS=True
#   EMAIL_HOST_USER=you@gmail.com
#   EMAIL_HOST_PASSWORD=your-16-char-app-password   # Google account "App password", not your login
#   DEFAULT_FROM_EMAIL=you@gmail.com
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@teak-blog.local
